VITE_API_BASE_URL=http://localhost:5000
# Firebase config (optional). Leave blank to run without auth.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_DEV_BYPASS=0
# Google Maps Embed API key (get one at https://console.cloud.google.com)
# Enable "Maps Embed API" for this key in the Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_embed_api_key_here
