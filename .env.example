############################################
# AI Job Screening Resume Analyzer (.env)  #
############################################

# Core App
APP_VERSION=0.4.0
DEV_BYPASS_AUTH=0
DATA_DIR=data
ALLOWED_ORIGINS=http://127.0.0.1:5176,http://localhost:5176

# Database & Queue (New)
MONGO_URI=your_mongodb_uri_here
REDIS_URL=your_redis_url_here

# Auth / Firebase
FIREBASE_CREDENTIAL_PATH=firebase-service-account.json

# LLM Providers
COHERE_API_KEY=your-cohere-key
OPENAI_API_KEY=your-openai-key
LLM_MODEL=cohere:command-light-nightly

# Email / Events
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com
WEBHOOK_URL=

# Optional overrides
# RATE_LIMIT_MAX=40
# RATE_LIMIT_WINDOW=60

# Do NOT commit a real .env file containing secrets.
# =============================
# Backend Environment Example
# =============================
# Copy to .env and fill in secrets. DO NOT COMMIT your real .env.

# App metadata
APP_VERSION=0.4.0

# Firebase Admin SDK service account path (JSON credentials file path)
FIREBASE_CREDENTIAL_PATH=firebase-service-account.json

# AI Providers
COHERE_API_KEY=your_cohere_key_here
OPENAI_API_KEY=your_openai_key_here
# Select model provider and model (cohere:* or openai:*)
LLM_MODEL=cohere:command-light-nightly

# Data + persistence
DATA_DIR=data

# Dev convenience (set to 1 ONLY locally; NEVER in production)
DEV_BYPASS_AUTH=0
ALLOWED_ORIGINS=http://127.0.0.1:5176,http://localhost:5176

# Email (optional; leave blank to disable sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

# Webhook (optional POST target for events)
WEBHOOK_URL=

# Rate limiting (future override possibilities)
# RATE_LIMIT_ANALYZE=40
# RATE_LIMIT_SAVE_VERSION=25

# Logging / future flags
# FEATURE_EMBEDDINGS=0
# FEATURE_ADVANCED_DIFF=0

# Google Maps (frontend)
# Get a Maps Embed API key from https://console.cloud.google.com
# Enable the "Maps Embed API" for your project and restrict the key to your domain.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_embed_api_key_here

# Foursquare Places API (backend) — for real coaching center search
# Sign up FREE at: https://location.foursquare.com/developer/
# Create a project → go to API Keys → copy your API key
# Free tier: 10,000 API calls total
FOURSQUARE_API_KEY=your_foursquare_api_key_here
